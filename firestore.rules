rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone can read to check phone, create to register,
    // update only own doc (by phone match), no deletes
    match /users/{userId} {
      allow read: if true;
      allow create: if request.resource.data.phone != null;
      allow update: if resource.data.phone == request.resource.data.phone;
      allow delete: if false;
    }

    // Groups: anyone can read/create, update by matching creator phone,
    // no deletes
    match /groups/{groupId} {
      allow read: if true;
      allow create: if request.resource.data.createdBy != null
                      && request.resource.data.name != null
                      && request.resource.data.inviteCode != null;
      allow update: if resource.data.createdBy == request.resource.data.createdBy
                      || request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if false;

      // Subcollections (members, contributions, timeline, events, etc.)
      match /{document=**} {
        allow read: if true;
        allow create: if request.resource.data != null;
        allow update: if request.resource.data != null;
        allow delete: if false;
      }
    }
  }
}
